generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Disciplina {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique @db.VarChar(50)
  descripcion String?
  activo      Boolean   @default(true)
  orden       Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  torneos   Torneo[]
  sesiones  Sesion[]

  @@map("disciplinas")
}

model Categoria {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique @db.VarChar(50)
  edadMin     Int      @map("edad_min")
  edadMax     Int      @map("edad_max")
  descripcion String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  torneos Torneo[]

  @@map("categorias")
}

model Espacio {
  id               Int      @id @default(autoincrement())
  nombre           String   @db.VarChar(100)
  ubicacion        String?
  capacidad        Int?
  horarioApertura  String   @default("07:00") @map("horario_apertura") @db.VarChar(5)
  horarioCierre    String   @default("22:00") @map("horario_cierre") @db.VarChar(5)
  activo           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  partidos Partido[]
  sesiones Sesion[]

  @@map("espacios")
}

model Torneo {
  id            Int      @id @default(autoincrement())
  nombre        String   @db.VarChar(150)
  disciplinaId  Int      @map("disciplina_id")
  categoriaId   Int      @map("categoria_id")
  tipo          String   @default("intercarreras") @db.VarChar(30)
  formato       String   @default("liga") @db.VarChar(30)
  temporada     String   @db.VarChar(20)
  fechaInicio   DateTime @map("fecha_inicio") @db.Date
  fechaFin      DateTime @map("fecha_fin") @db.Date
  estado        String   @default("planificado") @db.VarChar(20)
  reglas        String?
  creadoPorId   Int?     @map("creado_por_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  disciplina Disciplina @relation(fields: [disciplinaId], references: [id])
  categoria  Categoria  @relation(fields: [categoriaId], references: [id])
  equipos    Equipo[]
  partidos   Partido[]
  fixtures   Fixture[]
  tabla      TablaPosiciones[]

  @@map("torneos")
}

model Equipo {
  id           Int      @id @default(autoincrement())
  nombre       String   @db.VarChar(100)
  carreraId    Int?     @map("carrera_id")
  torneoId     Int      @map("torneo_id")
  entrenadorId Int?     @map("entrenador_id")
  delegadoId   Int?     @map("delegado_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  carrera           Carrera?          @relation(fields: [carreraId], references: [id])
  torneo            Torneo            @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  jugadores         EquipoJugador[]
  partidosLocal     Partido[]         @relation("PartidoLocal")
  partidosVisitante Partido[]         @relation("PartidoVisitante")
  estadisticas      EstadisticaPartido[]
  tabla             TablaPosiciones[]
  sesiones          Sesion[]

  @@unique([torneoId, carreraId])
  @@map("equipos")
}

model EquipoJugador {
  id                Int       @id @default(autoincrement())
  equipoId          Int       @map("equipo_id")
  deportistaId      Int       @map("deportista_id")
  deportistaCi      String    @map("deportista_ci") @db.VarChar(20)
  deportistaNombre  String    @map("deportista_nombre") @db.VarChar(150)
  numeroCamiseta    Int?      @map("numero_camiseta")
  posicion          String?   @db.VarChar(50)
  fechaInscripcion  DateTime  @default(now()) @map("fecha_inscripcion") @db.Date
  fechaBaja         DateTime? @map("fecha_baja") @db.Date
  habilitado        Boolean   @default(true)
  matriculaValidada Boolean   @default(false) @map("matricula_validada")
  fechaValidacion   DateTime? @map("fecha_validacion")

  equipo Equipo @relation(fields: [equipoId], references: [id], onDelete: Cascade)

  @@unique([equipoId, deportistaCi])
  @@map("equipo_jugadores")
}

model Partido {
  id                Int      @id @default(autoincrement())
  torneoId          Int      @map("torneo_id")
  equipoLocalId     Int      @map("equipo_local_id")
  equipoVisitanteId Int      @map("equipo_visitante_id")
  espacioId         Int?     @map("espacio_id")
  fecha             DateTime @db.Date
  hora              String   @db.VarChar(5)
  jornada           Int      @default(1)
  fase              String   @default("grupos") @db.VarChar(20)
  grupo             String?  @db.VarChar(5)
  golesLocal        Int      @default(0) @map("goles_local")
  golesVisitante    Int      @default(0) @map("goles_visitante")
  estado            String   @default("programado") @db.VarChar(20)
  actaUrl           String?  @map("acta_url")
  anotadorId        Int?     @map("anotador_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  torneo          Torneo               @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  equipoLocal     Equipo               @relation("PartidoLocal",     fields: [equipoLocalId],     references: [id])
  equipoVisitante Equipo               @relation("PartidoVisitante", fields: [equipoVisitanteId], references: [id])
  espacio         Espacio?             @relation(fields: [espacioId], references: [id])
  estadisticas    EstadisticaPartido[]

  @@map("partidos")
}

model EstadisticaPartido {
  id               Int      @id @default(autoincrement())
  partidoId        Int      @map("partido_id")
  equipoId         Int      @map("equipo_id")
  deportistaId     Int      @map("deportista_id")
  deportistaCi     String   @map("deportista_ci") @db.VarChar(20)
  deportistaNombre String   @map("deportista_nombre") @db.VarChar(150)
  tipo             String   @db.VarChar(30)
  minuto           Int?
  createdAt        DateTime @default(now()) @map("created_at")

  partido Partido @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  equipo  Equipo  @relation(fields: [equipoId],  references: [id])

  @@map("estadisticas_partido")
}

model Fixture {
  id            Int      @id @default(autoincrement())
  torneoId      Int      @map("torneo_id")
  generadoEn    DateTime @default(now()) @map("generado_en")
  formato       String   @db.VarChar(30)
  totalPartidos Int      @default(0) @map("total_partidos")
  observaciones String?

  torneo Torneo @relation(fields: [torneoId], references: [id], onDelete: Cascade)

  @@map("fixtures")
}

model TablaPosiciones {
  id                Int      @id @default(autoincrement())
  torneoId          Int      @map("torneo_id")
  equipoId          Int      @map("equipo_id")
  partidosJugados   Int      @default(0) @map("partidos_jugados")
  partidosGanados   Int      @default(0) @map("partidos_ganados")
  partidosEmpatados Int      @default(0) @map("partidos_empatados")
  partidosPerdidos  Int      @default(0) @map("partidos_perdidos")
  golesFavor        Int      @default(0) @map("goles_favor")
  golesContra       Int      @default(0) @map("goles_contra")
  diferenciaGoles   Int      @default(0) @map("diferencia_goles")
  puntos            Int      @default(0)
  updatedAt         DateTime @updatedAt @map("updated_at")

  torneo Torneo @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  equipo Equipo @relation(fields: [equipoId], references: [id], onDelete: Cascade)

  @@unique([torneoId, equipoId])
  @@map("tabla_posiciones")
}

model Sesion {
  id            Int      @id @default(autoincrement())
  equipoId      Int      @map("equipo_id")
  espacioId     Int?     @map("espacio_id")
  disciplinaId  Int      @map("disciplina_id")
  entrenadorId  Int?     @map("entrenador_id")
  fecha         DateTime @db.Date
  horaInicio    String   @map("hora_inicio") @db.VarChar(5)
  horaFin       String   @map("hora_fin") @db.VarChar(5)
  observaciones String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  equipo      Equipo      @relation(fields: [equipoId],     references: [id], onDelete: Cascade)
  espacio     Espacio?    @relation(fields: [espacioId],    references: [id])
  disciplina  Disciplina  @relation(fields: [disciplinaId], references: [id])
  asistencias Asistencia[]

  @@map("sesiones")
}

model Asistencia {
  id               Int      @id @default(autoincrement())
  sesionId         Int      @map("sesion_id")
  deportistaId     Int      @map("deportista_id")
  deportistaCi     String   @map("deportista_ci") @db.VarChar(20)
  deportistaNombre String   @map("deportista_nombre") @db.VarChar(150)
  presente         Boolean  @default(true)
  observacion      String?
  registradoPorId  Int?     @map("registrado_por_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  sesion Sesion @relation(fields: [sesionId], references: [id], onDelete: Cascade)

  @@unique([sesionId, deportistaCi])
  @@map("asistencia")
}

model Carrera {
  id       Int     @id @default(autoincrement())
  nombre   String  @unique @db.VarChar(150)
  facultad String  @db.VarChar(100)
  activo   Boolean @default(true)

  equipos Equipo[]

  @@map("carreras")
}
